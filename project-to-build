			viewButtons.forEach(button => {
				button.addEventListener('click', () => {
					// 移除所有按钮的活跃状态
					viewButtons.forEach(btn => btn.classList.remove('active'));
					// 为当前点击的按钮添加活跃状态
					button.classList.add('active');
					
